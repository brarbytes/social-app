{
  "expo": {
    "name": "SocialApp",
    "slug": "social-app",
    "version": "1.0.0",
    "scheme": "socialapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.socialapp.mobile",
      "newArchEnabled": true
    },
    "android": {
      "package": "com.socialapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "newArchEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
